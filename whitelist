
-- LocalScript in StarterPlayerScripts or GUI

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local remoteEvent = ReplicatedStorage:WaitForChild("SendClientID")

local RbxAnalyticsService = game:GetService("RbxAnalyticsService")
local clientId = RbxAnalyticsService:GetClientId()

-- Fire the RemoteEvent to send the Client ID to the server
remoteEvent:FireServer(clientId)

